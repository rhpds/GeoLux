# GeoLux Configuration
# Falls back to STARGATE_* equivalents where applicable

# ── Mode ──────────────────────────────────────────────────────────────
# live: real endpoints, real LLM calls, real stability measurement
# synthetic: synthetic client generates evidence, stability simulated
# replay: Kafka replay drives evidence stream from recorded events
GEOLUX_MODE=live

# ── Database ──────────────────────────────────────────────────────────
# Shares PostgreSQL with Stargate — tables prefixed with glx_
GEOLUX_DATABASE_URL=postgresql://geolux:geolux@localhost:5432/stargate

# ── LLM ───────────────────────────────────────────────────────────────
GEOLUX_LITELLM_URL=http://localhost:4000
GEOLUX_LITELLM_API_KEY=
GEOLUX_LLM_MODEL=granite-3-2-8b-instruct

# ── Geometric Stability ──────────────────────────────────────────────
GEOLUX_STABILITY_THRESHOLD=0.7
GEOLUX_STABILITY_METHOD=token_probability

# ── LLM-MPC ──────────────────────────────────────────────────────────
GEOLUX_MPC_HORIZON=2
GEOLUX_MPC_MAX_HORIZON=5
GEOLUX_MPC_MIN_HISTORY_WEEKS=4

# ── Deepfield ─────────────────────────────────────────────────────────
GEOLUX_GAUDI_URL=
GEOLUX_XEON6_URL=
GEOLUX_CONFIDENCE_THRESHOLD=0.7

# ── Kafka ─────────────────────────────────────────────────────────────
GEOLUX_KAFKA_BROKERS=localhost:9092

# ── Auth ──────────────────────────────────────────────────────────────
GEOLUX_ADMIN_API_KEY=
GEOLUX_API_KEYS=                   # JSON dict mapping key→roles: {"key1": ["geolux-admin"], "key2": ["read-only"]}

# ── SSO (Red Hat SSO / Keycloak OIDC) ────────────────────────────────
GEOLUX_SSO_ENABLED=false
GEOLUX_SSO_ISSUER_URL=
GEOLUX_SSO_CLIENT_ID=geolux
GEOLUX_SSO_REALM=redhat-external
GEOLUX_TRUST_PROXY_AUTH=false
GEOLUX_ADMIN_ROLES=geolux-admin,platform-admin

# ── Execution ─────────────────────────────────────────────────────────
GEOLUX_DRY_RUN=false
GEOLUX_SSL_VERIFY=true             # Set to "false" for internal self-signed certs
GEOLUX_EXECUTOR_KUBECONFIG=        # Path to executor kubeconfig (namespace-scoped write access)
GEOLUX_EXECUTOR_NAMESPACE=         # Default namespace for action execution

# ── Replay ────────────────────────────────────────────────────────────
GEOLUX_REPLAY_DIR=replay-archives

# ── CORS ──────────────────────────────────────────────────────────────
GEOLUX_CORS_ORIGINS=http://localhost:3000,http://localhost:8091
